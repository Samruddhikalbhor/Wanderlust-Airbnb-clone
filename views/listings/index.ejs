<% layout("/layouts/boilerPlate") %>
<body>
    <!-- <form method="get" action="/listings/new">
        <button>create new listing</button>
    </form> -->
    <h3>All Listings</h3>
    <div class="row row-cols-lg-3 row-cols-md-1 row-cols-sm-1">
        <% for(let listing of allListings){ %>
            <a href="/listings/<%=listing._id%>" class="listing-link">
            <div class="card col">
             <img src="<%=listing.image%>" class="card-img-top" alt="listingsimage" style="height:20rem;" />
             <div class="card-img-overlay"></div>
             <div class="card-body">
             <p class="card-text">
              <b><%=listing.title%><br></b>
              &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
             </p>
             </div>
            </div>
            </a>
           
        <% } %>
    </div>

    <ul>
    <% for(let listing of allListings){ %>
    <li><a href="/listings/<%= listing.id %>"><%= listing.title %></a></li>
    
    <% } %>
</ul>

</body>


